# PayGate V1 server environment
#
# Copy to .env.local for local development, or set these values in Vercel.
# Never commit real secrets.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

SESSION_SECRET=
API_SECRET_ENCRYPTION_KEY=
MPP_SECRET_KEY=

ESCROW_CONTRACT_ID=
PAYGATE_OPERATOR_SECRET=
PAYGATE_DEMO_UPSTREAM_SECRET=
PAYGATE_PUBLIC_ORIGIN=https://trypaygate.com

STELLAR_NETWORK=stellar:testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Local smoke-test-only overrides.
# Do not set these in Vercel.
# PAYGATE_AUTH_CHALLENGE_STORE=memory
# PAYGATE_REGISTRY_STORE=memory
# PAYGATE_MPP_VERIFY_MODE=mock
# PAYGATE_ESCROW_CREDIT_MODE=memory
