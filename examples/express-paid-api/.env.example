PORT=4000

# API owner wallet: receives USDC testnet payments.
STELLAR_RECIPIENT=G_REPLACE_WITH_RECIPIENT_PUBLIC_KEY

# Strong random string used by the MPP server to verify credentials.
MPP_SECRET_KEY=replace-with-random-string-at-least-32-chars

# Agent/client wallet: pays for the API call.
STELLAR_SECRET=S_REPLACE_WITH_PAYER_SECRET_KEY

# Paid API endpoint the agent will call.
PAYGATE_SAMPLE_URL=http://localhost:4000/v1/market-signal
# Production demo example:
# PAYGATE_SAMPLE_URL=https://your-vercel-domain.vercel.app/api/demo/market-signal
